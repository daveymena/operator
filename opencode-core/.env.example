# ============================================================
# OpenCode Evolved — Variables de entorno
# Copia este archivo como .env y rellena tus valores.
# En EasyPanel se configuran como Environment Variables del servicio.
# ============================================================

# --- Infraestructura base ---
PORT=3000
OPENCODE_PORT=21294
OPENCODE_INTERNAL_PORT=21294
OPERATOR_API_PORT=3001
WEB_OPERATOR_PORT=3001
AGENT_WS_PORT=21291
BRIDGE_PORT=21295
AGENT_SERVER_URL=ws://localhost:21291/agent
# Opcional: token para autenticar agentes y controllers
# AGENT_SERVER_TOKEN=tu-token-seguro

# Password de la UI de OpenCode (obligatorio en producción)
OPENCODE_SERVER_PASSWORD=tu-password-segura
OPENCODE_WORKSPACE=/workspace

# --- APIs de IA ---
# OpenCode/Zen Go/Copilot usa el engine local en 21294, pero los fallbacks usan estas keys:
GITHUB_COPILOT_TOKEN=tu-token-copilot-o-tid=...
USE_COPILOT_FIRST=true
COPILOT_MODEL=gpt-4o

FREEMODEL_API_KEY=tu-key-freemodel
FREEMODEL_BASE_URL=https://api.freemodel.dev/v1
FREEMODEL_MODEL=gpt-4o

GROQ_API_KEY=tu-key-groq
OPENROUTER_API_KEY=tu-key-openrouter
CEREBRAS_API_KEY=tu-key-cerebras
TOGETHER_AI_API_KEY=tu-key-together
ANTHROPIC_API_KEY=tu-key-anthropic
OPENAI_API_KEY=tu-key-openai
GOOGLE_GENERATIVE_AI_API_KEY=tu-key-gemini
MISTRAL_API_KEY=tu-key-mistral
XAI_API_KEY=tu-key-xai
PUTER_AUTH_TOKEN=
OLLAMA_HOST=http://localhost:11434

# OpenCode Zen (API gateway de opencode.ai — https://opencode.ai/auth)
OPENCODE_ZEN_API_KEY=sk-tu-key-zen

# --- Base de datos PostgreSQL (opcional) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=opencode
DB_PASSWORD=tu-password-db
DB_NAME=opencode
DATABASE_URL=postgres://opencode:tu-password-db@postgres:5432/opencode?sslmode=disable

# --- Skill: Claro Agent ---
# Monta el proyecto claro_agente_final en /app/skills/claro-agent/src
CLARO_SKILL_SRC=/app/skills/claro-agent/src
CLARO_SKILL_DATA=/app/skills-data/claro-agent
CLARO_FORM_URL=https://docs.google.com/forms/d/e/.../viewform
GOOGLE_EMAIL=tu-email@gmail.com
GOOGLE_PASSWORD=tu-password-google
GOOGLE_IMAP_PASSWORD=tu-app-password-gmail
TECH_CEDULA=123456789
TECH_NOMBRE=Tu Nombre
TECH_TELEFONO=3001234567
TECH_CIUDAD=Cali

# --- Skill: Preoperacional Nova ---
# Monta el proyecto preoperacional-Nova en /app/skills/preoperacional-nova/src
PREOP_SKILL_SRC=/app/skills/preoperacional-nova/src
PREOP_SKILL_DATA=/app/skills-data/preoperacional-nova
PREOP_URL=https://www.conectartv.com/SRCGC/Movilidad/preop_moto.php
PREOP_EMAIL=tu-email-nova@example.com
PREOP_PASSWORD=tu-password-nova
PREOP_SUPERVISOR=Nombre Supervisor
PREOP_SCHEDULE_HOUR=6
PREOP_SCHEDULE_MINUTE=30

# Notificaciones preoperacional (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
EMAIL_FROM=tu-email@gmail.com
EMAIL_TO=tu-email@gmail.com
TELEGRAM_BOT_TOKEN=tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# --- Puppeteer / Chromium ---
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
CHROME_BIN=/usr/bin/chromium
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
