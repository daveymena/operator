# ============================================================
#  OpenCode Evolved — Ejemplo de variables de entorno
#  COPIA este archivo como .env y rellena tus valores
#  El archivo .env NUNCA se sube a Git (.gitignore lo excluye)
# ============================================================

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
TZ=America/Bogota
DISPLAY=:99
OPENCODE_WORKSPACE=/workspace

# ── FreeModel (GPT-4o GRATIS — recomendado como primera opción)
# Registro gratuito en: https://freemodel.dev
FREEMODEL_API_KEY=
FREEMODEL_BASE_URL=https://api.freemodel.dev/v1
FREEMODEL_MODEL=gpt-4o

# ── OpenAI ────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic Claude ──────────────────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ── GRATUITOS (solo requieren registro) ──────────────────────
# Groq → https://console.groq.com/keys  (Llama, Mixtral, Gemma)
GROQ_API_KEY=
# OpenRouter → https://openrouter.ai/keys  (60+ modelos gratis con :free)
OPENROUTER_API_KEY=
# Cerebras → https://cloud.cerebras.ai  (ultrarrápido, gratis)
CEREBRAS_API_KEY=
# Together AI → https://api.together.xyz
TOGETHER_AI_API_KEY=

# ── Otros proveedores ─────────────────────────────────────────
MISTRAL_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=

# ── Puter.js (texto gratis sin API key) ──────────────────────
PUTER_AUTH_TOKEN=

# ── GitHub ───────────────────────────────────────────────────
# Crear en: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Telegram Bot (opcional) ───────────────────────────────────
# Crear con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ── Base de datos PostgreSQL ──────────────────────────────────
# Easypanel: copia la URL desde tu servicio PostgreSQL en el panel
EASYPANEL_DATABASE_URL=postgres://usuario:password@host:5432/nombre_bd
DB_HOST=postgres
DB_PORT=5432
DB_USER=opencode
DB_PASSWORD=opencode123
DB_NAME=opencode

# ── Ollama (modelos locales gratuitos) ────────────────────────
# Dejar vacío si no tienes Ollama instalado
# OLLAMA_HOST=http://localhost:11434

# ── Seguridad ─────────────────────────────────────────────────
OPENCODE_SERVER_PASSWORD=
GITHUB_TOKEN = ""
