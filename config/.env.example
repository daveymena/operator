# Operator Pro v3.0 — Configuration
# Copy this file to .env and fill in your API keys

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS (configure at least one)
# ═══════════════════════════════════════════════════════════════

# Fast & Free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# GitHub Copilot
GITHUB_COPILOT_TOKEN=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenCode
OPENCODE_ZEN_API_KEY=
OPENCODE_GO_API_KEY=

# Other providers
KIMI_API_KEY=
XIAOMI_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
HF_TOKEN=
XAI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# API Server
OPERATOR_PORT=3000
OPERATOR_HOST=0.0.0.0

# Authentication (leave empty for open access)
OPERATOR_API_KEY=

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# ═══════════════════════════════════════════════════════════════
# BROWSER CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Chrome/Chromium remote debugging port
BROWSER_DEBUG_PORT=9222

# Run browser in headless mode (true/false)
BROWSER_HEADLESS=true

# ═══════════════════════════════════════════════════════════════
# FACEBOOK AUTOMATION (optional)
# ═══════════════════════════════════════════════════════════════

FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT=
FACEBOOK_PAGE_ID=

# ═══════════════════════════════════════════════════════════════
# ADVANCED SETTINGS
# ═══════════════════════════════════════════════════════════════

# Maximum steps per task (default: 50)
MAX_STEPS=50

# Auto-confirm dangerous actions (true/false)
AUTO_CONFIRM=false

# Verbose logging (true/false)
VERBOSE=false

# Screenshot quality (1-100)
SCREENSHOT_QUALITY=80

# Screenshot scale (0.1-1.0)
SCREENSHOT_SCALE=0.75
