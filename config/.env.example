# ╔══════════════════════════════════════════════════════════════╗
# ║       🤖 Operator Pro v4.0 — Configuration                  ║
# ║                                                              ║
# ║  Primary:   OpenCode Zen  (https://opencode.ai/auth)        ║
# ║  Secondary: GMI Cloud     (https://www.gmicloud.ai/)        ║
# ║                                                              ║
# ║  At least one API key is required for AI functionality.     ║
# ║  Free models available via OpenCode Zen.                    ║
# ╚══════════════════════════════════════════════════════════════╝

# ═══ PRIMARY PROVIDERS ════════════════════════════════════════════
# OpenCode Zen — Curated gateway with Claude, GPT, Gemini, open models
# Sign up: https://opencode.ai/auth
# Free models: big-pickle, mimo-v2.5-free, minimax-m2.5-free, etc.
OPENCODE_ZEN_API_KEY=sk-your-opencode-zen-key
# Multiple keys for load balancing (optional):
# OPENCODE_ZEN_API_KEY_1=sk-key-1
# OPENCODE_ZEN_API_KEY_2=sk-key-2

# GMI Cloud — Hosted inference for frontier & open-weight models
# Sign up: https://www.gmicloud.ai/
GMI_API_KEY=gmi-your-gmi-key

# ═══ SECONDARY PROVIDERS ═════════════════════════════════════════
# OpenCode Go — Subscription plan for open models
# OPENCODE_GO_API_KEY=sk-your-opencode-go-key

# GitHub Copilot — GPT, Claude, Gemini models (included in subscription)
# GITHUB_COPILOT_TOKEN=ghu-your-copilot-token

# NVIDIA NIM — Nemotron, LLaMA, Qwen models
# NVIDIA_API_KEY=nvapi-your-nvidia-key

# ═══ DIRECT PROVIDERS ════════════════════════════════════════════
# Anthropic — Claude models (direct API)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# OpenAI — GPT models (direct API)
# OPENAI_API_KEY=sk-your-openai-key

# Google Gemini — Free tier available
# GOOGLE_API_KEY=AIza-your-google-key

# DeepSeek — Best value reasoning models
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Z.AI / GLM — Zhipu AI models
# GLM_API_KEY=your-zai-key

# Kimi / Moonshot — Kimi reasoning models
# KIMI_API_KEY=sk-your-kimi-key

# xAI — Grok models
# XAI_API_KEY=xai-your-xai-key

# Alibaba DashScope — Qwen models
# DASHSCOPE_API_KEY=sk-your-dashscope-key

# Hugging Face — Open models
# HF_TOKEN=hf_your-hf-token

# ═══ FREE PROVIDERS ══════════════════════════════════════════════
# Nous Portal — Free research portal (OAuth)
# NOUS_API_KEY=your-nous-key

# FreeModel.dev — Free model gateway
# FREEMODEL_API_KEY=your-freemodel-key

# ═══ SERVER CONFIGURATION ════════════════════════════════════════
# Operator Pro server
OPERATOR_PORT=3000
OPERATOR_HOST=0.0.0.0
OPERATOR_API_KEY=op-admin-your-secret-key
OPERATOR_JWT_SECRET=your-jwt-secret-change-this

# ═══ SAFETY ══════════════════════════════════════════════════════
# Watch Mode: requires user presence on financial/social sites
# WATCH_MODE=true

# Auto-confirm dangerous actions (use with caution)
# AUTO_CONFIRM=false

# ═══ SCHEDULER ═══════════════════════════════════════════════════
# Webhook URL for scheduler notifications (optional)
# SCHEDULER_NOTIFY_URL=https://your-webhook.example.com/notify

# ═══ AUTO-RESTART CONFIGURATION ══════════════════════════════════
# When all tokens are exhausted, Operator Pro will:
# 1. Try to rotate to another token
# 2. Try to renew tokens (ping test, daily reset check)
# 3. Activate fallback providers
# 4. If nothing works → restart the process (Docker will auto-start it again)
#
# Cooldown between restart attempts (ms)
# RESTART_COOLDOWN_MS=300000
#
# Maximum auto-restart attempts before giving up
# MAX_RESTART_ATTEMPTS=10

# ═══ MULTIPLE API KEYS (for load balancing) ════════════════════
# Add multiple keys per provider for rotation when one gets rate limited
# OPENCODE_ZEN_API_KEY_2=sk-your-second-key
# OPENCODE_ZEN_API_KEY_3=sk-your-third-key
