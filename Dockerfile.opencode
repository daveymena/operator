FROM node:22-slim

ENV NODE_ENV=production

WORKDIR /app

COPY package*.json ./
RUN npm install --omit=dev

COPY opencode-core/package*.json ./opencode-core/
RUN cd opencode-core && npm install --omit=dev

COPY . .

EXPOSE 21294

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD node -e "require('http').get('http://localhost:21294/health', r => process.exit(r.statusCode===200?0:1))" || exit 1

CMD ["node", "opencode-core/serve.js"]
